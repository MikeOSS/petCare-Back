# Copia este ficheiro para .env e preenche os valores.

# Postgres (alinhado com docker-compose: base ignite, sem senha em dev)
DATABASE_URL=postgresql://postgres@localhost:5432/ignite

# Obrigatório para login e sessões — usa uma string longa e aleatória em produção
JWT_SECRET=muda-este-valor-no-teu-.env

# CORS (browser). Várias origens: separa por vírgula.
# Em NODE_ENV=development, se omitires esta linha, o back aceita qualquer origem local (reflect).
# Ex.: Expo web: http://localhost:8081 ou http://127.0.0.1:8081
# FRONT_END_ORIGIN=http://localhost:8081

# Opcional (default 3001)
SERVER_PORT=3001

# Opcional — só se usares domínio próprio para cookies
# COOKIE_DOMAIN=
