{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "lib": ["es2024"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["./*"]
    },
    "resolveJsonModule": true
  },
  "include": ["src", "core"],
  "exclude": ["tests", "node_modules", "dist", ".dagger", "scripts", "logs", ".husky"]
}
