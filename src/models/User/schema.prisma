model User {
  id                 String     @id @default(cuid())
  first_name         String?
  last_name          String?
  password           String?
  email              String     @unique
  role               Role       @default(BASIC)
  status             UserStatus @default(ACTIVE)
  invite_token       String?
  invite_expire_date DateTime?
  created_at         DateTime   @default(now())
  updated_at         DateTime   @updatedAt
  sessions           Session[]

  @@map("users")
}

enum Role {
  ADMIN
  BASIC
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}
